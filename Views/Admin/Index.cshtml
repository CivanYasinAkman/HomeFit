@{ ViewData["Title"] = "Admin Panel"; }

<div style="background:#0d0d1a;min-height:100vh;padding:40px 20px;color:white;">
    <div style="max-width:1000px;margin:0 auto;">

        <div style="display:flex;justify-content:space-between;
                    align-items:flex-start;margin-bottom:32px;">
            <div>
                <h2 style="font-size:22px;margin-bottom:4px;">Admin Paneli</h2>
                <p style="color:#6b7280;font-size:13px;">
                    Platform istatistikleri ve yönetim araçları
                </p>
            </div>
            <div style="color:#6b7280;font-size:12px;text-align:right;">
                @DateTime.Now.ToString("dd.MM.yyyy HH:mm")
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div style="background:#0d2a1a;border:1px solid #00c853;border-radius:8px;
                        padding:12px 16px;margin-bottom:20px;font-size:13px;color:#00c853;">
                ✅ @TempData["Success"]
            </div>
        }

        <!-- İstatistik Kartları -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);
                    gap:16px;margin-bottom:32px;">
            <div style="background:#111827;border:1px solid #1e1e2e;
                        border-radius:12px;padding:24px;">
                <div style="color:#6b7280;font-size:11px;margin-bottom:8px;">
                    TOPLAM KULLANICI
                </div>
                <div style="font-size:36px;font-weight:900;color:#00bcd4;">
                    @ViewBag.TotalUsers
                </div>
            </div>
            <div style="background:#111827;border:1px solid #1e1e2e;
                        border-radius:12px;padding:24px;">
                <div style="color:#6b7280;font-size:11px;margin-bottom:8px;">
                    PREMIUM ÜYE
                </div>
                <div style="font-size:36px;font-weight:900;color:#f59e0b;">
                    @ViewBag.PremiumUsers
                </div>
                <div style="color:#6b7280;font-size:11px;margin-top:4px;">
                    @(ViewBag.TotalUsers > 0
                        ? Math.Round((double)ViewBag.PremiumUsers
                            / (double)ViewBag.TotalUsers * 100, 1)
                        : 0)% oranında
                </div>
            </div>
            <div style="background:#111827;border:1px solid #1e1e2e;
                        border-radius:12px;padding:24px;">
                <div style="color:#6b7280;font-size:11px;margin-bottom:8px;">
                    TOPLAM EGZERSİZ
                </div>
                <div style="font-size:36px;font-weight:900;color:#00c853;">
                    @ViewBag.TotalExercises
                </div>
            </div>
            <div style="background:#111827;border:1px solid #1e1e2e;
                        border-radius:12px;padding:24px;">
                <div style="color:#6b7280;font-size:11px;margin-bottom:8px;">
                    TOPLAM SEANS
                </div>
                <div style="font-size:36px;font-weight:900;color:#a78bfa;">
                    @ViewBag.TotalSessions
                </div>
            </div>
        </div>

        <!-- Yönetim Kartları -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <a href="/Admin/Users"
               style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                      padding:28px;text-decoration:none;color:white;display:block;
                      transition:border-color 0.2s;">
                <div style="font-size:36px;margin-bottom:14px;">👥</div>
                <div style="font-size:16px;font-weight:bold;margin-bottom:6px;">
                    Kullanıcı Yönetimi
                </div>
                <div style="color:#6b7280;font-size:13px;margin-bottom:16px;">
                    Kullanıcıları listele, ara, filtrele ve sil
                </div>
                <div style="color:#00bcd4;font-size:13px;font-weight:bold;">
                    Kullanıcılara Git →
                </div>
            </a>

            <a href="/Admin/Exercises"
               style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                      padding:28px;text-decoration:none;color:white;display:block;">
                <div style="font-size:36px;margin-bottom:14px;">🏋️</div>
                <div style="font-size:16px;font-weight:bold;margin-bottom:6px;">
                    Egzersiz Yönetimi
                </div>
                <div style="color:#6b7280;font-size:13px;margin-bottom:16px;">
                    Egzersiz ekle, düzenle ve sil
                </div>
                <div style="color:#00bcd4;font-size:13px;font-weight:bold;">
                    Egzersizlere Git →
                </div>
            </a>

            <a href="/api/stats"
               style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                      padding:28px;text-decoration:none;color:white;display:block;">
                <div style="font-size:36px;margin-bottom:14px;">📊</div>
                <div style="font-size:16px;font-weight:bold;margin-bottom:6px;">
                    API İstatistikleri
                </div>
                <div style="color:#6b7280;font-size:13px;margin-bottom:16px;">
                    JSON formatında platform verisi
                </div>
                <div style="color:#00bcd4;font-size:13px;font-weight:bold;">
                    API'yi Görüntüle →
                </div>
            </a>

            <a href="/Exercise"
               style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                      padding:28px;text-decoration:none;color:white;display:block;">
                <div style="font-size:36px;margin-bottom:14px;">💪</div>
                <div style="font-size:16px;font-weight:bold;margin-bottom:6px;">
                    Egzersiz Kütüphanesi
                </div>
                <div style="color:#6b7280;font-size:13px;margin-bottom:16px;">
                    Kullanıcı görünümünde egzersizleri gör
                </div>
                <div style="color:#00bcd4;font-size:13px;font-weight:bold;">
                    Kütüphaneye Git →
                </div>
            </a>
        </div>

    </div>
</div>