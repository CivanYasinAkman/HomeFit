@model IEnumerable<HomeFit.Models.User>
@{ ViewData["Title"] = "Kullanıcı Yönetimi"; }

<div style="background:#0d0d1a;min-height:100vh;padding:40px 20px;color:white;">
    <div style="max-width:1000px;margin:0 auto;">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
            <div>
                <a href="/Admin" style="color:#6b7280;font-size:13px;text-decoration:none;">← Admin Panel</a>
                <h2 style="font-size:20px;margin-top:4px;">Kullanıcı Yönetimi</h2>
                <p style="color:#6b7280;font-size:13px;">Toplam @ViewBag.TotalCount kullanıcı</p>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div style="background:#0d2a1a;border:1px solid #00c853;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#00c853;">
                ✅ @TempData["Success"]
            </div>
        }

        <!-- Arama -->
        <form method="get" style="margin-bottom:20px;display:flex;gap:12px;">
            <input name="search" value="@ViewBag.Search" placeholder="İsim veya email ile ara..."
                   style="flex:1;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;" />
            <button type="submit"
                    style="background:#00bcd4;color:#000;border:none;border-radius:8px;padding:10px 20px;font-size:13px;font-weight:bold;cursor:pointer;">
                Ara
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a href="/Admin/Users"
                   style="background:#1e1e2e;color:#fff;border-radius:8px;padding:10px 16px;font-size:13px;text-decoration:none;display:flex;align-items:center;">
                    Temizle
                </a>
            }
        </form>

        <!-- Tablo -->
        <div style="background:#111827;border:1px solid #1e1e2e;border-radius:12px;overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;font-size:13px;">
                <thead>
                    <tr style="border-bottom:1px solid #1e1e2e;">
                        <th style="padding:14px 16px;text-align:left;color:#6b7280;font-weight:600;">KULLANICI</th>
                        <th style="padding:14px 16px;text-align:left;color:#6b7280;font-weight:600;">ROL</th>
                        <th style="padding:14px 16px;text-align:left;color:#6b7280;font-weight:600;">ÜYELİK</th>
                        <th style="padding:14px 16px;text-align:left;color:#6b7280;font-weight:600;">KAYIT TARİHİ</th>
                        <th style="padding:14px 16px;text-align:left;color:#6b7280;font-weight:600;">İŞLEM</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr style="border-bottom:1px solid #1a1a2e;">
                            <td style="padding:14px 16px;">
                                <div style="font-weight:bold;">@user.Name</div>
                                <div style="color:#6b7280;font-size:12px;">@user.Email</div>
                            </td>
                            <td style="padding:14px 16px;">
                                @if (user.Role == "Admin")
                                {
                                    <span style="background:#1a0d2e;color:#a78bfa;font-size:11px;padding:3px 10px;border-radius:20px;">Admin</span>
                                }
                                else
                                {
                                    <span style="background:#1a1a2e;color:#6b7280;font-size:11px;padding:3px 10px;border-radius:20px;">User</span>
                                }
                            </td>
                            <td style="padding:14px 16px;">
                                @if (user.MembershipTier == "Premium")
                                {
                                    <span style="background:#2a1a0e;color:#f59e0b;font-size:11px;padding:3px 10px;border-radius:20px;">⭐ Premium</span>
                                }
                                else
                                {
                                    <span style="background:#1a1a2e;color:#6b7280;font-size:11px;padding:3px 10px;border-radius:20px;">Free</span>
                                }
                            </td>
                            <td style="padding:14px 16px;color:#6b7280;">
                                @user.JoinDate.ToString("dd.MM.yyyy")
                            </td>
                            <td style="padding:14px 16px;">
                                @if (user.Role != "Admin")
                                {
                                    <form asp-action="DeleteUser" method="post" style="display:inline;"
                                          onsubmit="return confirm('@user.Name adlı kullanıcıyı silmek istediğinizden emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.UserId" />
                                        <button type="submit"
                                                style="background:#1a0000;color:#ef4444;border:1px solid #ef4444;padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer;">
                                            Sil
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:#2a2a3e;font-size:12px;">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Sayfalama -->
        @if (ViewBag.TotalPages > 1)
        {
            <div style="display:flex;gap:8px;justify-content:center;margin-top:20px;">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="/Admin/Users?page=@i&search=@ViewBag.Search"
                       style="background:@(i == ViewBag.CurrentPage ? "#00bcd4" : "#1e1e2e");color:@(i == ViewBag.CurrentPage ? "#000" : "#fff");padding:8px 14px;border-radius:6px;text-decoration:none;font-size:13px;font-weight:bold;">
                        @i
                    </a>
                }
            </div>
        }

    </div>
</div>