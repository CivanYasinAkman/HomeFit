@model HomeFit.Models.ErrorViewModel
@{ ViewData["Title"] = "Hata"; Layout = null; }

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Hata — HomeFit</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #0d0d1a; color: white; font-family: 'Segoe UI', sans-serif;
               min-height: 100vh; display: flex; align-items: center;
               justify-content: center; text-align: center; padding: 40px; }
        .icon { font-size: 56px; margin-bottom: 16px; }
        h2 { font-size: 22px; margin-bottom: 8px; }
        p { color: #6b7280; font-size: 14px; margin-bottom: 28px; }
        code { background: #1e1e2e; padding: 4px 10px; border-radius: 6px;
               font-size: 12px; color: #9ca3af; }
        .links { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
        a.btn { background: #00bcd4; color: #000; padding: 10px 24px;
                border-radius: 8px; text-decoration: none;
                font-weight: bold; font-size: 13px; }
        a.outline { background: transparent; color: #fff; border: 1px solid #2a2a3e;
                    padding: 10px 24px; border-radius: 8px;
                    text-decoration: none; font-size: 13px; }
    </style>
</head>
<body>
    <div>
        <div class="icon">⚠️</div>
        <h2>Bir hata oluştu.</h2>
        <p>İsteğiniz işlenirken beklenmeyen bir sorun meydana geldi.</p>

        @if (Model.ShowRequestId)
        {
            <p style="margin-bottom:24px;">
                Hata ID: <code>@Model.RequestId</code>
            </p>
        }

        <div class="links">
            <a href="/" class="btn">Ana Sayfaya Dön</a>
            <a href="javascript:history.back()" class="outline">Geri Git</a>
        </div>
    </div>
</body>
</html>