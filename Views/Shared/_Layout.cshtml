<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HomeFit</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #0d0d1a; color: white; font-family: 'Segoe UI', sans-serif; }
        nav { background: #0d0d1a; border-bottom: 1px solid #1e1e2e; padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
        .nav-logo { color: #00bcd4; font-size: 18px; font-weight: bold; text-decoration: none; }
        .nav-links { display: flex; align-items: center; gap: 24px; }
        .nav-links a { color: #9ca3af; font-size: 13px; text-decoration: none; }
        .nav-links a:hover { color: #fff; }
        .nav-btn { background: #00bcd4; color: #000 !important; padding: 7px 18px; border-radius: 8px; font-weight: bold; font-size: 13px; }
        .nav-btn:hover { background: #00acc1 !important; }
        .nav-outline { border: 1px solid #2a2a3e; color: #fff !important; padding: 7px 18px; border-radius: 8px; font-size: 13px; }
        .nav-user { color: #9ca3af; font-size: 13px; }
        main { min-height: calc(100vh - 60px); }
    </style>
</head>
<body>
<nav>
    <a class="nav-logo" href="/">HomeFit</a>
    <div class="nav-links">
        <a href="/Exercise">Egzersizler</a>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a href="/Home/Dashboard">Dashboard</a>
            <a href="/Account/Profile">Profilim</a>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin">Admin Panel</a>
            }
            <a href="/Account/Logout">Çıkış</a>
        }
        else
        {
            <a href="/Account/Login" class="nav-outline">Giriş Yap</a>
            <a href="/Account/Register" class="nav-btn">Ücretsiz Başla</a>
        }
    </div>
</nav>
<main>
    @RenderBody()
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>