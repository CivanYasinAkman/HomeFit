@{
    ViewData["Title"] = "HomeFit - Evde Spor, Sana Özel";
}

<div style="background: linear-gradient(135deg, #0d0d1a, #1a1a2e); min-height: 100vh; color: white; padding: 60px;">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
        <h1 style="font-size: 48px; color: #00bcd4; margin-bottom: 20px;">HomeFit</h1>
        <p style="font-size: 20px; color: #888; margin-bottom: 40px;">
            Evde, ekipmansız, kendi hızında. Sana özel program seni bekliyor.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="/Onboarding" style="background: #00bcd4; color: #000; padding: 14px 32px; border-radius: 10px; text-decoration: none; font-weight: bold; font-size: 16px;">
                Ücretsiz Başla
            </a>
            <a href="/Exercise" style="background: transparent; color: #fff; padding: 14px 32px; border-radius: 10px; text-decoration: none; font-size: 16px; border: 1px solid #444;">
                Egzersizleri Gör
            </a>
        </div>
        <div style="display: flex; gap: 48px; justify-content: center; margin-top: 60px;">
            <div>
                <div style="font-size: 28px; font-weight: bold; color: #00bcd4;">200+</div>
                <div style="color: #555; font-size: 12px;">Egzersiz</div>
            </div>
            <div>
                <div style="font-size: 28px; font-weight: bold; color: #00bcd4;">Free</div>
                <div style="color: #555; font-size: 12px;">Başlangıç Planı</div>
            </div>
            <div>
                <div style="font-size: 28px; font-weight: bold; color: #00bcd4;">GIF</div>
                <div style="color: #555; font-size: 12px;">Görsel Rehber</div>
            </div>
        </div>
    </div>
</div>