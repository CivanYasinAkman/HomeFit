@{ ViewData["Title"] = "Profil Oluştur"; }

<div style="background:#0d0d1a;min-height:100vh;padding:60px 20px;color:white;">
    <div style="max-width:600px;margin:0 auto;">
        <h2 style="color:#fff;margin-bottom:4px;">Profilinizi Oluşturun</h2>
        <p style="color:#6b7280;font-size:13px;margin-bottom:32px;">
            Size özel program oluşturabilmemiz için birkaç bilgiye ihtiyacımız var.
        </p>

        <form asp-controller="Onboarding" asp-action="Submit" method="post"
              style="background:#111827;border:1px solid #1e1e2e;border-radius:16px;padding:40px;">
            @Html.AntiForgeryToken()

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
                <div>
                    <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Yaş</label>
                    <input name="Age" type="number" min="10" max="100"
                           style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;"
                           placeholder="25" />
                </div>
                <div>
                    <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Kilo (kg)</label>
                    <input name="Weight" type="number" step="0.1"
                           style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;"
                           placeholder="70" />
                </div>
                <div>
                    <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Boy (cm)</label>
                    <input name="Height" type="number" step="0.1"
                           style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;"
                           placeholder="170" />
                </div>
                <div>
                    <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Cinsiyet</label>
                    <select name="Gender"
                            style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;">
                        <option value="">Seçin...</option>
                        <option value="female">Kadın</option>
                        <option value="male">Erkek</option>
                    </select>
                </div>
                <div>
                    <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Fitness Seviyesi</label>
                    <select name="FitnessLevel"
                            style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;">
                        <option value="">Seçin...</option>
                        <option value="beginner">Başlangıç</option>
                        <option value="intermediate">Orta</option>
                        <option value="advanced">İleri</option>
                    </select>
                </div>
                <div>
                    <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Hedef</label>
                    <select name="Goal"
                            style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;">
                        <option value="">Seçin...</option>
                        <option value="fat_loss">Kilo Vermek</option>
                        <option value="muscle_gain">Kas Kazanmak</option>
                        <option value="maintain">Form Korumak</option>
                    </select>
                </div>
            </div>

            <div style="margin-bottom:24px;">
                <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Mevcut Ekipman</label>
                <select name="Equipment"
                        style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;">
                    <option value="none">Ekipman Yok (Vücut Ağırlığı)</option>
                    <option value="dumbbell">Dumbbell</option>
                    <option value="barbell">Barbell</option>
                    <option value="resistance_band">Direnç Bandı</option>
                    <option value="full_gym">Tam Gym Ekipmanı</option>
                </select>
            </div>

            <button type="submit"
                    style="width:100%;background:#00bcd4;color:#000;border:none;border-radius:10px;padding:14px;font-size:14px;font-weight:bold;cursor:pointer;">
                Programımı Oluştur →
            </button>
        </form>
    </div>
</div>