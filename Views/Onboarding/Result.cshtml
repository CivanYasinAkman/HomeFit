@{
    ViewData["Title"] = "Programınız Hazır";
}

<div style="background: #0d0d1a; min-height: 100vh; padding: 60px 20px; color: white;">
    <div style="max-width: 600px; margin: 0 auto; text-align: center;">
        <div style="font-size: 48px; margin-bottom: 16px;">🎉</div>
        <h2 style="color: #fff; margin-bottom: 8px;">Merhaba, @ViewBag.UserName!</h2>
        <p style="color: #888; margin-bottom: 40px;">Profilinize göre programınız oluşturuldu.</p>

        <div style="background: #111; border-radius: 16px; padding: 32px; border: 1px solid #1e1e2e; margin-bottom: 32px;">
            <div style="color: #00bcd4; font-size: 12px; margin-bottom: 8px;">Atanan Program</div>
            <div style="color: #fff; font-size: 18px; font-weight: bold;">@ViewBag.Program</div>
        </div>

        <div style="display: flex; gap: 12px; justify-content: center;">
            <a href="/Exercise" style="background: #00bcd4; color: #000; padding: 12px 28px; border-radius: 10px; text-decoration: none; font-weight: bold;">
                Egzersizleri Gör
            </a>
            <a href="/" style="background: transparent; color: #fff; padding: 12px 28px; border-radius: 10px; text-decoration: none; border: 1px solid #444;">
                Ana Sayfaya Dön
            </a>
        </div>
    </div>
</div>