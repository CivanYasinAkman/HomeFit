@model HomeFit.Models.Exercise

@{
    ViewData["Title"] = Model.Name;
}

<div style="background: #0d0d1a; min-height: 100vh; padding: 40px; color: white;">
    <a href="/Exercise" style="color: #00bcd4; text-decoration: none; font-size: 13px;">← Geri</a>

    <div style="max-width: 800px; margin: 24px auto 0;">
        <h2 style="color: #fff; margin-bottom: 8px;">@Model.Name</h2>
        <p style="color: #555; margin-bottom: 32px;">@Model.MuscleGroup · @Model.Difficulty</p>

        <div style="background: #1e1e2e; border-radius: 16px; padding: 32px; margin-bottom: 24px;">
            <div style="background: #2a2a3e; border-radius: 12px; height: 280px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; border: 1px dashed #333;">
                <span style="color: #444;">[ @Model.Name — Tek Tekrar GIF ]</span>
            </div>

            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 24px;">
                <label style="color: #888; font-size: 13px;">Tekrar Sayısı:</label>
                <button onclick="changeRep(-1)" style="width: 32px; height: 32px; background: #2a2a3e; border: none; border-radius: 8px; color: white; font-size: 16px; cursor: pointer;">−</button>
                <span id="repValue" style="font-size: 20px; font-weight: bold; color: #00bcd4; min-width: 36px; text-align: center;">10</span>
                <button onclick="changeRep(1)" style="width: 32px; height: 32px; background: #2a2a3e; border: none; border-radius: 8px; color: white; font-size: 16px; cursor: pointer;">+</button>
            </div>

            <div style="display: flex; gap: 12px;">
                <button onclick="startExercise()" id="startBtn"
                        style="flex: 1; background: #00bcd4; color: #000; border: none; border-radius: 10px; padding: 12px; font-size: 14px; font-weight: bold; cursor: pointer;">
                    ▶ Başla
                </button>
                <button onclick="resetExercise()"
                        style="background: #1e1e2e; color: #fff; border: none; border-radius: 10px; padding: 12px 20px; font-size: 14px; cursor: pointer;">
                    ↺
                </button>
            </div>

            <div id="counter" style="display: none; text-align: center; margin-top: 20px; font-size: 24px; font-weight: bold; color: #00bcd4;">
                0 / <span id="totalReps">10</span>
            </div>

            <div id="doneMsg" style="display: none; margin-top: 20px; background: #0d2a1a; border: 1px solid #00c853; border-radius: 10px; padding: 16px; text-align: center;">
                <div style="font-size: 24px; margin-bottom: 8px;">✅</div>
                <div style="color: #00c853; font-size: 15px; font-weight: bold;">Set Tamamlandı!</div>
            </div>
        </div>

        <div style="background: #1e1e2e; border-radius: 12px; padding: 20px;">
            <h4 style="color: #00bcd4; margin-bottom: 10px;">Egzersiz Bilgisi</h4>
            <p style="color: #888; font-size: 13px; line-height: 1.6;">@Model.Description</p>
        </div>
    </div>
</div>

<script>
    let reps = 10;
    let currentRep = 0;
    let interval = null;
    let running = false;

    function changeRep(delta) {
        if (running) return;
        reps = Math.max(1, Math.min(30, reps + delta));
        document.getElementById('repValue').textContent = reps;
        document.getElementById('totalReps').textContent = reps;
    }

    function startExercise() {
        if (running) return;
        running = true;
        currentRep = 0;
        document.getElementById('counter').style.display = 'block';
        document.getElementById('doneMsg').style.display = 'none';
        document.getElementById('startBtn').textContent = '⏳ Devam Ediyor...';
        document.getElementById('startBtn').style.opacity = '0.6';

        interval = setInterval(() => {
            currentRep++;
            document.getElementById('counter').innerHTML = currentRep + ' / <span id="totalReps">' + reps + '</span>';
            if (currentRep >= reps) {
                clearInterval(interval);
                running = false;
                document.getElementById('doneMsg').style.display = 'block';
                document.getElementById('startBtn').textContent = '▶ Başla';
                document.getElementById('startBtn').style.opacity = '1';
            }
        }, 2000);
    }

    function resetExercise() {
        clearInterval(interval);
        running = false;
        currentRep = 0;
        document.getElementById('counter').style.display = 'none';
        document.getElementById('doneMsg').style.display = 'none';
        document.getElementById('startBtn').textContent = '▶ Başla';
        document.getElementById('startBtn').style.opacity = '1';
    }
</script>