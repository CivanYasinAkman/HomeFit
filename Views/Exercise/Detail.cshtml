@model HomeFit.Models.Exercise
@{ ViewData["Title"] = Model.Name; }

<div style="background:#0d0d1a;min-height:100vh;padding:40px 20px;color:white;">
    <a href="/Exercise" style="color:#00bcd4;text-decoration:none;font-size:13px;">← Egzersiz Kütüphanesi</a>

    <div style="max-width:800px;margin:24px auto 0;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:8px;">
            <h2 style="color:#fff;font-size:24px;">@Model.Name</h2>
            @if (Model.IsPremium)
            {
                <span style="background:#2a1a0e;color:#f59e0b;font-size:12px;padding:5px 14px;border-radius:20px;font-weight:bold;">⭐ Premium</span>
            }
        </div>
        <p style="color:#6b7280;margin-bottom:32px;font-size:13px;">
            @Model.MuscleGroup · @Model.Difficulty
            @if (Model.Equipment != "None") { <text>· @Model.Equipment</text> }
        </p>

        <div style="background:#111827;border:1px solid #1e1e2e;border-radius:16px;padding:32px;margin-bottom:24px;">

            <!-- GIF Gösterimi -->
            <div style="background:#1e1e2e;border-radius:12px;height:300px;display:flex;align-items:center;justify-content:center;margin-bottom:24px;overflow:hidden;">
                @if (!string.IsNullOrEmpty(Model.GifUrl) && Model.GifUrl.StartsWith("http"))
                {
                    <img id="exerciseGif" src="@Model.GifUrl" alt="@Model.Name"
                         style="max-height:100%;max-width:100%;object-fit:contain;" />
                }
                else
                {
                    <span style="color:#444;font-size:13px;">[ @Model.Name — Tek Tekrar GIF ]</span>
                }
            </div>

            <!-- Tekrar Seçici -->
            <div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;">
                <label style="color:#6b7280;font-size:13px;">Tekrar Sayısı:</label>
                <button onclick="changeRep(-1)"
                        style="width:36px;height:36px;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;color:white;font-size:18px;cursor:pointer;">−</button>
                <span id="repValue"
                      style="font-size:22px;font-weight:bold;color:#00bcd4;min-width:40px;text-align:center;">10</span>
                <button onclick="changeRep(1)"
                        style="width:36px;height:36px;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;color:white;font-size:18px;cursor:pointer;">+</button>
            </div>

            <!-- Butonlar -->
            <div style="display:flex;gap:12px;margin-bottom:16px;">
                <button onclick="startExercise()" id="startBtn"
                        style="flex:1;background:#00bcd4;color:#000;border:none;border-radius:10px;padding:13px;font-size:14px;font-weight:bold;cursor:pointer;">
                    ▶ Başla
                </button>
                <button onclick="pauseExercise()" id="pauseBtn"
                        style="display:none;background:#f59e0b;color:#000;border:none;border-radius:10px;padding:13px;font-size:14px;font-weight:bold;cursor:pointer;">
                    ⏸ Duraklat
                </button>
                <button onclick="resetExercise()"
                        style="background:#1e1e2e;color:#fff;border:1px solid #2a2a3e;border-radius:10px;padding:13px 20px;font-size:14px;cursor:pointer;">
                    ↺ Sıfırla
                </button>
            </div>

            <!-- Sayaç -->
            <div id="counter"
                 style="display:none;text-align:center;padding:20px;background:#0d1a2e;border-radius:10px;margin-bottom:12px;">
                <div style="color:#6b7280;font-size:12px;margin-bottom:4px;">TAMAMLANAN TEKRAR</div>
                <div style="font-size:40px;font-weight:900;color:#00bcd4;">
                    <span id="currentRep">0</span>
                    <span style="color:#2a2a3e;font-size:24px;"> / </span>
                    <span id="totalReps" style="color:#2a2a3e;font-size:24px;">10</span>
                </div>
            </div>

            <!-- Tamamlandı Mesajı -->
            <div id="doneMsg"
                 style="display:none;background:#0d2a1a;border:1px solid #00c853;border-radius:10px;padding:20px;text-align:center;">
                <div style="font-size:32px;margin-bottom:8px;">✅</div>
                <div style="color:#00c853;font-size:16px;font-weight:bold;">Set Tamamlandı!</div>
                <div style="color:#6b7280;font-size:13px;margin-top:4px;">Harika iş! Dinlen ve tekrar başla.</div>
            </div>
        </div>

        <!-- Egzersiz Bilgisi -->
        <div style="background:#111827;border:1px solid #1e1e2e;border-radius:12px;padding:24px;">
            <h4 style="color:#00bcd4;margin-bottom:12px;font-size:14px;">Doğru Form ve Teknik</h4>
            <p style="color:#9ca3af;font-size:13px;line-height:1.7;">@Model.Description</p>

            <div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap;">
                <div style="background:#1e1e2e;border-radius:8px;padding:10px 16px;font-size:12px;">
                    <span style="color:#6b7280;">Kas Grubu:</span>
                    <span style="color:#00bcd4;margin-left:6px;">@Model.MuscleGroup</span>
                </div>
                <div style="background:#1e1e2e;border-radius:8px;padding:10px 16px;font-size:12px;">
                    <span style="color:#6b7280;">Zorluk:</span>
                    <span style="color:#fff;margin-left:6px;">@Model.Difficulty</span>
                </div>
                <div style="background:#1e1e2e;border-radius:8px;padding:10px 16px;font-size:12px;">
                    <span style="color:#6b7280;">Ekipman:</span>
                    <span style="color:#fff;margin-left:6px;">@Model.Equipment</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let reps = 10;
    let currentRep = 0;
    let interval = null;
    let running = false;
    let paused = false;

    function changeRep(delta) {
        if (running) return;
        reps = Math.max(1, Math.min(50, reps + delta));
        document.getElementById('repValue').textContent = reps;
        document.getElementById('totalReps').textContent = reps;
    }

    function startExercise() {
        if (running) return;
        running = true;
        paused = false;
        document.getElementById('counter').style.display = 'block';
        document.getElementById('doneMsg').style.display = 'none';
        document.getElementById('startBtn').style.display = 'none';
        document.getElementById('pauseBtn').style.display = 'block';

        interval = setInterval(() => {
            currentRep++;
            document.getElementById('currentRep').textContent = currentRep;
            if (currentRep >= reps) {
                clearInterval(interval);
                running = false;
                document.getElementById('doneMsg').style.display = 'block';
                document.getElementById('pauseBtn').style.display = 'none';
                document.getElementById('startBtn').style.display = 'block';
                document.getElementById('startBtn').textContent = '▶ Tekrar Başla';
            }
        }, 2000);
    }

    function pauseExercise() {
        if (!running) return;
        if (!paused) {
            clearInterval(interval);
            paused = true;
            document.getElementById('pauseBtn').textContent = '▶ Devam Et';
        } else {
            paused = false;
            document.getElementById('pauseBtn').textContent = '⏸ Duraklat';
            interval = setInterval(() => {
                currentRep++;
                document.getElementById('currentRep').textContent = currentRep;
                if (currentRep >= reps) {
                    clearInterval(interval);
                    running = false;
                    document.getElementById('doneMsg').style.display = 'block';
                    document.getElementById('pauseBtn').style.display = 'none';
                    document.getElementById('startBtn').style.display = 'block';
                }
            }, 2000);
        }
    }

    function resetExercise() {
        clearInterval(interval);
        running = false;
        paused = false;
        currentRep = 0;
        document.getElementById('currentRep').textContent = '0';
        document.getElementById('counter').style.display = 'none';
        document.getElementById('doneMsg').style.display = 'none';
        document.getElementById('startBtn').style.display = 'block';
        document.getElementById('startBtn').textContent = '▶ Başla';
        document.getElementById('pauseBtn').style.display = 'none';
    }
</script>