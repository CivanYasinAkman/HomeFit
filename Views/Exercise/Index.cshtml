@model IEnumerable<HomeFit.Models.Exercise>

@{
    ViewData["Title"] = "Egzersiz Kütüphanesi";
}

<div style="background: #0d0d1a; min-height: 100vh; padding: 40px; color: white;">
    <h2 style="color: #00bcd4; margin-bottom: 8px;">Egzersiz Kütüphanesi</h2>
    <p style="color: #888; margin-bottom: 32px;">Tüm egzersizleri inceleyin ve programınıza ekleyin.</p>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
        @foreach (var exercise in Model)
        {
            <div style="background: #1e1e2e; border-radius: 12px; padding: 20px; border: 1px solid #2a2a3e;">
                <div style="background: #2a2a3e; border-radius: 8px; height: 160px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                    <span style="color: #555; font-size: 12px;">[ GIF: @exercise.Name ]</span>
                </div>
                <h3 style="color: #fff; margin-bottom: 8px;">@exercise.Name</h3>
                <div style="display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                    <span style="background: #0d1a1e; color: #00bcd4; font-size: 11px; padding: 3px 10px; border-radius: 6px;">@exercise.MuscleGroup</span>
                    <span style="background: #1a1a2e; color: #888; font-size: 11px; padding: 3px 10px; border-radius: 6px;">@exercise.Difficulty</span>
                    @if (exercise.IsPremium)
                    {
                        <span style="background: #2a1a0e; color: #f59e0b; font-size: 11px; padding: 3px 10px; border-radius: 6px;">Premium</span>
                    }
                </div>
                <a href="/Exercise/Detail/@exercise.ExerciseId"
                   style="display: block; background: #00bcd4; color: #000; text-align: center; padding: 8px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 13px;">
                    Egzersizi Gör
                </a>
            </div>
        }
    </div>
</div>