@model HomeFit.Models.User
@{ ViewData["Title"] = "Profilim"; }

<div style="background:#0d0d1a;min-height:100vh;padding:40px 20px;color:white;">
    <div style="max-width:700px;margin:0 auto;">

        <h2 style="font-size:22px;margin-bottom:4px;">Profilim</h2>
        <p style="color:#6b7280;font-size:13px;margin-bottom:32px;">
            Hesap bilgilerin ve üyelik durumun
        </p>

        @if (TempData["Success"] != null)
        {
            <div style="background:#0d2a1a;border:1px solid #00c853;border-radius:8px;
                        padding:12px 16px;margin-bottom:20px;font-size:13px;color:#00c853;">
                ✅ @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="background:#1a0000;border:1px solid #ef4444;border-radius:8px;
                        padding:12px 16px;margin-bottom:20px;font-size:13px;color:#ef4444;">
                ⚠️ @TempData["Error"]
            </div>
        }

        <!-- Kullanıcı Kartı -->
        <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                    padding:24px;margin-bottom:20px;display:flex;
                    align-items:center;gap:20px;">
            <div style="width:68px;height:68px;background:#1e1e2e;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;
                        font-size:30px;flex-shrink:0;">
                👤
            </div>
            <div style="flex:1;">
                <div style="font-size:20px;font-weight:bold;">@Model.Name</div>
                <div style="color:#6b7280;font-size:13px;margin-top:2px;">@Model.Email</div>
                <div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap;">
                    @if (Model.MembershipTier == "Premium")
                    {
                        <span style="background:#2a1a0e;color:#f59e0b;font-size:11px;
                                     padding:4px 12px;border-radius:20px;font-weight:bold;">
                            ⭐ Premium Üye
                        </span>
                    }
                    else
                    {
                        <span style="background:#1a1a2e;color:#6b7280;font-size:11px;
                                     padding:4px 12px;border-radius:20px;">
                            Free Üye
                        </span>
                    }
                    <span style="background:#0d1a1e;color:#00bcd4;font-size:11px;
                                 padding:4px 12px;border-radius:20px;">
                        @Model.Role
                    </span>
                    <span style="background:#1a1a2e;color:#6b7280;font-size:11px;
                                 padding:4px 12px;border-radius:20px;">
                        Üye: @Model.JoinDate.ToString("dd.MM.yyyy")
                    </span>
                </div>
            </div>
        </div>

        <!-- Fiziksel Bilgiler -->
        <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                    padding:24px;margin-bottom:20px;">
            <div style="display:flex;justify-content:space-between;
                        align-items:center;margin-bottom:16px;">
                <h4 style="color:#00bcd4;font-size:13px;">Fiziksel Bilgiler</h4>
                <a href="/Account/EditProfile"
                   style="color:#6b7280;font-size:12px;text-decoration:none;">
                    ✏️ Düzenle
                </a>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
                @foreach (var item in new[] {
                    new { label = "Yaş", value = Model.Age > 0 ? Model.Age + " yaş" : "—" },
                    new { label = "Kilo", value = Model.Weight > 0 ? Model.Weight + " kg" : "—" },
                    new { label = "Boy", value = Model.Height > 0 ? Model.Height + " cm" : "—" },
                    new { label = "Cinsiyet", value = Model.Gender == "male" ? "Erkek" : Model.Gender == "female" ? "Kadın" : "—" },
                    new { label = "Fitness Seviyesi", value = Model.FitnessLevel ?? "—" },
                    new { label = "Hedef", value = Model.Goal == "fat_loss" ? "Kilo Vermek" : Model.Goal == "muscle_gain" ? "Kas Kazanmak" : Model.Goal == "maintain" ? "Form Korumak" : "—" }
                })
                {
                    <div style="background:#1e1e2e;border-radius:10px;padding:14px;">
                        <div style="color:#6b7280;font-size:11px;margin-bottom:4px;">
                            @item.label.ToUpper()
                        </div>
                        <div style="font-size:14px;font-weight:bold;">@item.value</div>
                    </div>
                }
            </div>
        </div>

        <!-- Aktif Program -->
        @if (Model.UserProgram?.Program != null)
        {
            <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                        padding:24px;margin-bottom:20px;">
                <h4 style="color:#00bcd4;font-size:13px;margin-bottom:12px;">Aktif Program</h4>
                <div style="background:#1e1e2e;border-radius:10px;padding:16px;
                            display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <div style="font-size:15px;font-weight:bold;">
                            @Model.UserProgram.Program.Name
                        </div>
                        <div style="color:#6b7280;font-size:12px;margin-top:4px;">
                            @Model.UserProgram.Program.Description
                        </div>
                    </div>
                    <a href="/Onboarding"
                       style="background:#1e1e2e;color:#00bcd4;border:1px solid #00bcd4;
                              padding:6px 14px;border-radius:8px;font-size:12px;
                              text-decoration:none;">
                        Güncelle
                    </a>
                </div>
            </div>
        }

        <!-- Abonelik -->
        <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;
                    padding:24px;margin-bottom:20px;">
            <h4 style="color:#f59e0b;font-size:13px;margin-bottom:16px;">Üyelik Durumu</h4>
            @if (Model.MembershipTier == "Premium")
            {
                <div style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <div style="font-size:15px;font-weight:bold;color:#f59e0b;">
                            ⭐ Premium Üye
                        </div>
                        @if (Model.Subscription != null)
                        {
                            <div style="color:#6b7280;font-size:12px;margin-top:4px;">
                                Bitiş: @Model.Subscription.EndDate.ToString("dd.MM.yyyy")
                            </div>
                        }
                    </div>
                    <a href="/Subscription/Cancel"
                       style="color:#6b7280;font-size:12px;text-decoration:none;">
                        İptal Et
                    </a>
                </div>
            }
            else
            {
                <div style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <div style="font-size:15px;font-weight:bold;">Free Plan</div>
                        <div style="color:#6b7280;font-size:12px;margin-top:4px;">
                            Premium'a geçerek tüm içeriklere eriş
                        </div>
                    </div>
                    <a href="/Subscription/Upgrade"
                       style="background:#f59e0b;color:#000;padding:8px 18px;
                              border-radius:8px;text-decoration:none;font-size:13px;
                              font-weight:bold;">
                        ⭐ Upgrade
                    </a>
                </div>
            }
        </div>

        <!-- Tehlikeli Bölge -->
        <div style="background:#111827;border:1px solid #2a0000;border-radius:14px;padding:24px;">
            <h4 style="color:#ef4444;font-size:13px;margin-bottom:12px;">Tehlikeli Bölge</h4>
            <p style="color:#6b7280;font-size:13px;margin-bottom:16px;">
                Hesabını silersen tüm veriler kalıcı olarak silinir. Bu işlem geri alınamaz.
            </p>
            <form asp-action="DeleteAccount" method="post"
                  onsubmit="return confirm('Hesabınızı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.')">
                @Html.AntiForgeryToken()
                <button type="submit"
                        style="background:transparent;color:#ef4444;border:1px solid #ef4444;
                               padding:10px 20px;border-radius:8px;font-size:13px;cursor:pointer;">
                    🗑️ Hesabımı Sil
                </button>
            </form>
        </div>

    </div>
</div>