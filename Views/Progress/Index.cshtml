@{ ViewData["Title"] = "İlerleme Takibi"; }

<div style="background:#0d0d1a;min-height:100vh;padding:40px 20px;color:white;">
    <div style="max-width:900px;margin:0 auto;">

        <h2 style="font-size:22px;margin-bottom:4px;">İlerleme Takibi</h2>
        <p style="color:#6b7280;font-size:13px;margin-bottom:32px;">Seans geçmişin ve vücut ölçümlerini takip et.</p>

        @if (TempData["Success"] != null)
        {
            <div style="background:#0d2a1a;border:1px solid #00c853;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#00c853;">
                ✅ @TempData["Success"]
            </div>
        }

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;">

            <!-- Kilo Kaydet -->
            <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;padding:24px;">
                <h4 style="color:#00bcd4;font-size:14px;margin-bottom:16px;">⚖️ Ölçüm Kaydet</h4>
                <form asp-action="LogWeight" method="post">
                    @Html.AntiForgeryToken()
                    <div style="margin-bottom:12px;">
                        <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Kilo (kg)</label>
                        <input name="weight" type="number" step="0.1" required placeholder="70.5"
                               style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;" />
                    </div>
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Vücut Yağ % (opsiyonel)</label>
                        <input name="bodyFatPercentage" type="number" step="0.1" placeholder="18.5"
                               style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;" />
                    </div>
                    <button type="submit"
                            style="width:100%;background:#00bcd4;color:#000;border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:bold;cursor:pointer;">
                        Kaydet
                    </button>
                </form>
            </div>

            <!-- Seans Kaydet -->
            <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;padding:24px;">
                <h4 style="color:#a78bfa;font-size:14px;margin-bottom:16px;">💪 Seans Kaydet</h4>
                <form asp-action="LogSession" method="post">
                    @Html.AntiForgeryToken()
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:12px;color:#9ca3af;margin-bottom:6px;">Süre (dakika)</label>
                        <input name="durationMinutes" type="number" required placeholder="45"
                               style="width:100%;background:#1e1e2e;border:1px solid #2a2a3e;border-radius:8px;padding:10px 14px;color:#fff;font-size:13px;outline:none;" />
                    </div>
                    <button type="submit"
                            style="width:100%;background:#a78bfa;color:#000;border:none;border-radius:8px;padding:10px;font-size:13px;font-weight:bold;cursor:pointer;">
                        Seansı Kaydet
                    </button>
                </form>
            </div>
        </div>

        <!-- Seans Grafiği -->
        @{
            var sessions = ViewBag.Sessions as List<HomeFit.Models.WorkoutSession>;
            var progressLogs = ViewBag.ProgressLogs as List<HomeFit.Models.Progress>;
        }

        @if (sessions != null && sessions.Any())
        {
            <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;padding:24px;margin-bottom:20px;">
                <h4 style="color:#fff;font-size:14px;margin-bottom:16px;">📊 Antrenman Sıklığı</h4>
                <canvas id="sessionChart" height="80"></canvas>
            </div>
        }

        @if (progressLogs != null && progressLogs.Any())
        {
            <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;padding:24px;margin-bottom:20px;">
                <h4 style="color:#fff;font-size:14px;margin-bottom:16px;">⚖️ Kilo Değişimi</h4>
                <canvas id="weightChart" height="80"></canvas>
            </div>
        }

        <!-- Seans Geçmişi -->
        <div style="background:#111827;border:1px solid #1e1e2e;border-radius:14px;padding:24px;">
            <h4 style="color:#fff;font-size:14px;margin-bottom:16px;">📋 Seans Geçmişi</h4>

            @if (sessions == null || !sessions.Any())
            {
                <div style="text-align:center;padding:32px;color:#6b7280;">
                    <div style="font-size:32px;margin-bottom:8px;">🏋️</div>
                    <p style="font-size:13px;">Henüz seans kaydın yok. İlk antrenmanını kaydet!</p>
                </div>
            }
            else
            {
                <div style="display:grid;gap:10px;">
                    @foreach (var session in sessions)
                    {
                        <div style="background:#1e1e2e;border-radius:10px;padding:14px 18px;display:flex;justify-content:space-between;align-items:center;">
                            <div>
                                <div style="font-size:13px;font-weight:bold;">
                                    @session.StartDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                                </div>
                                <div style="color:#6b7280;font-size:12px;margin-top:2px;">
                                    @session.DurationMinutes dakika
                                </div>
                            </div>
                            <span style="background:#0d2a1a;color:#00c853;font-size:11px;padding:4px 12px;border-radius:20px;">
                                ✓ @session.Status
                            </span>
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
    const chartDefaults = {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
            x: { ticks: { color: '#6b7280' }, grid: { color: '#1e1e2e' } },
            y: { ticks: { color: '#6b7280' }, grid: { color: '#1e1e2e' } }
        }
    };

    @if (sessions != null && sessions.Any())
    {
        <text>
        new Chart(document.getElementById('sessionChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(ViewBag.SessionDatesJson),
                datasets: [{
                    data: @Html.Raw(ViewBag.SessionCountsJson),
                    backgroundColor: '#00bcd4',
                    borderRadius: 6
                }]
            },
            options: chartDefaults
        });
        </text>
    }

    @if (progressLogs != null && progressLogs.Any())
    {
        <text>
        new Chart(document.getElementById('weightChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(ViewBag.WeightDatesJson),
                datasets: [{
                    data: @Html.Raw(ViewBag.WeightValuesJson),
                    borderColor: '#a78bfa',
                    backgroundColor: 'rgba(167,139,250,0.1)',
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#a78bfa',
                    pointRadius: 5
                }]
            },
            options: chartDefaults
        });
        </text>
    }
</script>